{
  "name": "@skyturn/ui-canvas",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./workflow-runtime": {
      "types": "./src/workflowRuntime.ts",
      "import": "./dist/workflowRuntime.js",
      "default": "./dist/workflowRuntime.js"
    },
    "./composer": {
      "types": "./src/composer.ts",
      "import": "./dist/composer.js",
      "default": "./dist/composer.js"
    },
    "./styles.css": "./src/styles.css"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "pnpm run typecheck",
    "test": "vitest run src"
  },
  "dependencies": {
    "@gsap/react": "^2.1.2",
    "@skyturn/agent-runtime": "workspace:*",
    "@skyturn/git-worktree": "workspace:*",
    "@skyturn/orchestrator": "workspace:*",
    "@skyturn/persistence": "workspace:*",
    "@skyturn/planner": "workspace:*",
    "@skyturn/project-core": "workspace:*",
    "@xyflow/react": "^12.11.0",
    "diff2html": "^3.4.56",
    "dompurify": "^3.4.10",
    "gsap": "^3.15.0",
    "lucide-react": "^1.17.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
