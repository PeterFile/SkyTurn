{
  "name": "@skyturn/persistence",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./workflow-store": {
      "types": "./src/workflowStore.ts",
      "import": "./dist/workflowStore.js",
      "default": "./dist/workflowStore.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "pnpm run typecheck",
    "test": "vitest run src",
    "flow-kernel:acceptance": "pnpm --filter @skyturn/workflow-kernel build && vitest run src/flowKernelStore.acceptance.test.ts"
  },
  "dependencies": {
    "@skyturn/git-worktree": "workspace:*",
    "@skyturn/project-core": "workspace:*",
    "@skyturn/workflow-kernel": "workspace:*",
    "better-sqlite3": "^12.10.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.9.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
