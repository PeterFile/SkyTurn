{
  "name": "@skyturn/workflow-kernel",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./acceptance": {
      "types": "./src/acceptance.ts",
      "import": "./dist/acceptance.js",
      "default": "./dist/acceptance.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "pnpm run typecheck",
    "test": "vitest run src",
    "flow-kernel:acceptance": "vitest run src/flowKernel.acceptance.test.ts"
  },
  "dependencies": {
    "@skyturn/project-core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.0.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
