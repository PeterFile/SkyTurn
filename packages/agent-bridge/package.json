{
  "name": "@skyturn/agent-bridge",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "files": [
    "dist",
    "dist/native/artifact-gate.ps1",
    "src"
  ],
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "pnpm run native:build && tsc -p tsconfig.json && pnpm run native:copy",
    "native:build": "node scripts/buildArtifactGate.mjs",
    "native:copy": "node scripts/buildArtifactGate.mjs --copy-dist",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "pnpm run typecheck",
    "test": "pnpm run native:build && vitest run src"
  },
  "dependencies": {
    "@skyturn/agent-runtime": "workspace:*",
    "@skyturn/project-core": "workspace:*",
    "@skyturn/workflow-kernel": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.0.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
